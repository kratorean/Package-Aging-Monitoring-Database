import psycopg2
import os
import glob

# ✅ Connect to PostgreSQL
def get_connection():
    return psycopg2.connect(
        dbname="Abuja_Inbound_Delivery_Actitity_DB",
        user="postgres",
        password="password",
        host="localhost",
        port="5432"
    )

# ✅ Load into staging table
def load_csv_to_staging(csv_path, staging_table, conn, sep=","):
    cur = conn.cursor()
    with open(csv_path, 'r') as f:
        copy_sql = f"""
        COPY {staging_table}
        FROM STDIN
        WITH CSV HEADER DELIMITER '{sep}';
        """
        cur.copy_expert(copy_sql, f)
    conn.commit()
    cur.close()
    print(f"✔ Loaded {csv_path} into staging table {staging_table}")

# ✅ Deduplicate inserts (for inbound + tundra)
def insert_from_staging_dedup(staging_table, main_table, conn, pk_column="tracking_number"):
    cur = conn.cursor()
    insert_sql = f"""
    INSERT INTO {main_table}
    SELECT * FROM {staging_table}
    ON CONFLICT ({pk_column}) DO NOTHING;
    """
    cur.execute(insert_sql)
    conn.commit()
    cur.close()
    print(f"✔ Deduplicated insert from {staging_table} → {main_table}")

# ✅ Allow all inserts (for driverload)
def insert_from_staging_all(staging_table, main_table, conn):
    cur = conn.cursor()
    insert_sql = f"""
    INSERT INTO {main_table}
    SELECT * FROM {staging_table};
    """
    cur.execute(insert_sql)
    conn.commit()
    cur.close()
    print(f"✔ Inserted all rows from {staging_table} → {main_table}")

# ✅ Clear staging
def clear_staging(staging_table, conn):
    cur = conn.cursor()
    cur.execute(f"TRUNCATE {staging_table};")
    conn.commit()
    cur.close()

# 📌 PROCESS FUNCTIONS
def process_inbound(conn):
    inbound_files = glob.glob(os.path.join(
        r'C:\Users\Co\Documents\SQL_PROJECTS\Daily_Inbound_Reports', "Inbound_*.csv"))
    for f in inbound_files:
        print(f"Processing inbound file: {f}")
        load_csv_to_staging(f, 'inbound_arrivals_staging', conn, sep=",")
        insert_from_staging_dedup('inbound_arrivals_staging', 'inbound_arrivals', conn, pk_column="tracking_number")
        clear_staging('inbound_arrivals_staging', conn)

def process_driverload(conn):
    driver_files = glob.glob(os.path.join(
        r'C:\Users\Co\Documents\SQL_PROJECTS\Driver_load_reports\DriverLoadReports', "Driverloadreport_*.csv"))
    for f in driver_files:
        print(f"Processing driverload file: {f}")
        load_csv_to_staging(f, 'driverload_staging', conn, sep=",")
        insert_from_staging_all('driverload_staging', 'driverload_report_table', conn)
        clear_staging('driverload_staging', conn)

def process_tundra(conn):
    tundra_files = glob.glob(os.path.join(
        r'C:\Users\Co\Documents\SQL_PROJECTS\TundraManifests', "*_tundra_manifest.csv"))
    for f in tundra_files:
        print(f"Processing tundra file: {f}")
        load_csv_to_staging(f, 'tundra_staging', conn, sep=",")
        insert_from_staging_dedup('tundra_staging', 'tundra_manifest', conn, pk_column="tracking_number")
        clear_staging('tundra_staging', conn)

# ✅ Main workflow
def main():
    conn = get_connection()
    choice = input("Which dataset do you want to process? (inbound/driverload/tundra/all): ").strip().lower()

    if choice == "inbound":
        process_inbound(conn)
    elif choice == "driverload":
        process_driverload(conn)
    elif choice == "tundra":
        process_tundra(conn)
    elif choice == "all":
        process_inbound(conn)
        process_driverload(conn)
        process_tundra(conn)
    else:
        print("❌ Invalid choice")

    conn.close()
    print("🎉 Done!")

if __name__ == "__main__":
    main()
